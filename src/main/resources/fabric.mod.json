{
	"schemaVersion": 1,
	"id": "umbrellas",
	"version": "${version}",
	"name": "Umbrellas",
	"description": "Adds Umbrellas that can shelter you from the elements (and look incredibly stylish!)",
	"authors": [
		"Pneumono"
	],
	"contact": {
		"homepage": "https://modrinth.com/project/dgTb67Ox",
		"sources": "https://github.com/PneumonoIsNotAvailable/Umbrellas",
		"issues": "https://github.com/PneumonoIsNotAvailable/Umbrellas/issues"
	},
	"custom": {
		"modmenu": {
			"links": {
				"modmenu.donate": "https://ko-fi.com/pneumono",
				"modmenu.discord": "https://discord.gg/ap6wD2XUzs",
				"modmenu.modrinth": "https://modrinth.com/project/dgTb67Ox",
				"modmenu.wiki": "https://github.com/PneumonoIsNotAvailable/Umbrellas/wiki"
			}
		}
	},
	"license": "MIT",
	"icon": "assets/umbrellas/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.pneumono.umbrellas.Umbrellas"
		],
		"client": [
			"net.pneumono.umbrellas.UmbrellasClient"
		],
		"fabric-datagen": [
			"net.pneumono.umbrellas.UmbrellasDataGenerator"
		]
	},
	"mixins": [
		"umbrellas.mixins.json",
		{
			"config": "umbrellas.client.mixins.json5",
			"environment": "client"
		}
	],
	"accessWidener": "accesswideners/${aw_file}",
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": "${supported_versions}",
		"java": ">=${java}",
		"fabric-api": "*",
		"pneumonocore": "*"
	},
	"suggests": {
		"modmenu": "*"
	}
}